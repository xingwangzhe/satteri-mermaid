{
  "name": "@xingwangzhe/satteri-mermaid",
  "version": "0.1.4",
  "description": "Satteri MDAST plugin for Mermaid diagram detection and transformation",
  "keywords": [
    "astro",
    "astro-component",
    "diagram",
    "markdown",
    "mdast",
    "mermaid",
    "plugin",
    "satteri"
  ],
  "homepage": "https://github.com/xingwangzhe/satteri-mermaid#readme",
  "license": "MIT",
  "author": "xingwangzhe",
  "repository": {
    "type": "git",
    "url": "https://github.com/xingwangzhe/satteri-mermaid"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    }
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build && tsc --emitDeclarationOnly --declarationDir dist",
    "test": "vitest run",
    "test:watch": "vitest",
    "fmt": "oxfmt",
    "fmt:check": "oxfmt --check",
    "lint": "oxlint src test",
    "lint:fix": "oxlint --fix src test",
    "prepublishOnly": "bun run build"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "mermaid": "^11.15.0",
    "oxfmt": "^0.55.0",
    "oxlint": "^1.70.0",
    "satteri": "^0.9.0",
    "typescript": "^5.9.0",
    "vite": "^8.0.0",
    "vitest": "^4.1.0"
  },
  "peerDependencies": {
    "mermaid": ">=11.0.0",
    "satteri": ">=0.8.0"
  }
}
